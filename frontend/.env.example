# NextAuth (required for auth to work)
# Generate a secret: npx auth secret
AUTH_SECRET=

# Base URL — must match where your app is served (no trailing slash).
# Dev: http://localhost:3000   Prod: https://yourdomain.com
# Add this EXACT URL + /api/auth/callback/google to Google "Authorized redirect URIs".
AUTH_URL=http://localhost:3000

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
# Authorized redirect URIs must include exactly: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ColabFold base URL — no trailing slash (spawn + poll: POST / returns job_id, GET /result?job_id= returns result)
# 1) Ephemeral: run "cd colabfold_modal && modal serve app.py", copy the URL for "web" (keep terminal open)
# 2) Persistent: run "modal deploy app.py", copy the deployed web URL (no -dev)
# Example: https://YOUR_WORKSPACE--colabfold-genaigenesis-web-dev.modal.run
NEXT_PUBLIC_COLABFOLD_PREDICT_URL=

# Supabase (Projects PDF storage). Create a Storage bucket named "pdfs" in the Supabase dashboard.
# Project URL: Settings → API → Project URL. Anon key: Settings → API → anon public.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Langflow — Genome Primer Design Agent
# 1) Install: pip install langflow
# 2) Start: langflow run  (defaults to http://127.0.0.1:7860)
# 3) Import the flow JSON: backend/Genome Primer Design Agent FINAL.json
# 4) Copy the flow ID from the Langflow UI (or use the default below)
LANGFLOW_BASE_URL=http://127.0.0.1:7860
LANGFLOW_FLOW_ID=26233de8-e4d6-427a-a2be-938d9990a93d
